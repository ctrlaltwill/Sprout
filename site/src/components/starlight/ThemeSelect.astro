---
import { LaptopIcon, MoonIcon, SunIcon } from "@lucide/astro";
---

<starlight-theme-select>
  <div
    data-slot="tabs"
    data-orientation="horizontal"
    data-default-value="auto"
    class="lk-theme-tabs"
    data-value="auto"
  >
    <div
      role="tablist"
      data-slot="tabs-list"
      data-variant="indicator"
      class="lk-theme-tablist"
      aria-label="Theme"
    >
      <div aria-hidden="true" data-slot="tabs-indicator" class="lk-theme-indicator"></div>
      <button title="Light theme" type="button" role="tab" data-slot="tabs-trigger" data-value="light" class="lk-theme-tab">
        <SunIcon class="size-4" />
      </button>
      <button title="Dark theme" type="button" role="tab" data-slot="tabs-trigger" data-value="dark" class="lk-theme-tab">
        <MoonIcon class="size-4" />
      </button>
      <button title="Auto (system)" type="button" role="tab" data-slot="tabs-trigger" data-value="auto" class="lk-theme-tab">
        <LaptopIcon class="size-4" />
      </button>
    </div>
  </div>
</starlight-theme-select>

<script is:inline>
  window.StarlightThemeProvider?.updatePickers();
</script>

<script>
  type Theme = "auto" | "dark" | "light";

  const storageKey = "starlight-theme";

  const parseTheme = (theme: unknown): Theme =>
    theme === "auto" || theme === "dark" || theme === "light" ? theme : "auto";

  const loadTheme = (): Theme =>
    parseTheme(typeof localStorage !== "undefined" && localStorage.getItem(storageKey));

  const storeTheme = (theme: Theme): void => {
    if (typeof localStorage !== "undefined") {
      localStorage.setItem(storageKey, theme === "auto" ? "" : theme);
    }
  };

  const getPreferredColorScheme = (): Exclude<Theme, "auto"> =>
    matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";

  const syncPickers = (theme: Theme): void => {
    document.querySelectorAll("starlight-theme-select").forEach((picker) => {
      if (!(picker instanceof HTMLElement)) return;
      const tabsRoot = picker.querySelector("[data-slot='tabs']");
      if (!(tabsRoot instanceof HTMLElement)) return;

      tabsRoot.dataset.value = theme;

      picker.querySelectorAll("[role='tab']").forEach((tab, index) => {
        if (!(tab instanceof HTMLButtonElement)) return;
        const selected = tab.dataset.value === theme;
        tab.setAttribute("aria-selected", String(selected));
        tab.setAttribute("tabindex", selected ? "0" : "-1");
        tab.dataset.state = selected ? "active" : "inactive";
        if (selected) {
          tabsRoot.style.setProperty("--active-tab-left", `${tab.offsetLeft}px`);
          tabsRoot.style.setProperty("--active-tab-width", `${tab.offsetWidth}px`);
          tabsRoot.style.setProperty("--active-tab-top", `${tab.offsetTop}px`);
          tabsRoot.style.setProperty("--active-tab-height", `${tab.offsetHeight}px`);
          tabsRoot.dataset.defaultValue = theme;
        }

        if (!selected && index === 0 && !picker.querySelector("[data-state='active']")) {
          tab.setAttribute("tabindex", "0");
        }
      });
    });
  };

  const applyTheme = (theme: Theme): void => {
    const resolved = theme === "auto" ? getPreferredColorScheme() : theme;
    document.documentElement.dataset.theme = resolved;
    document.documentElement.dataset.themeChoice = theme;
    document.documentElement.classList.toggle("dark", resolved === "dark");
    storeTheme(theme);
    window.StarlightThemeProvider?.updatePickers(theme);
    syncPickers(theme);
  };

  matchMedia("(prefers-color-scheme: light)").addEventListener("change", () => {
    if (loadTheme() === "auto") applyTheme("auto");
  });

  class StarlightThemeSelect extends HTMLElement {
    constructor() {
      super();
      const tabs = [...this.querySelectorAll("[role='tab']")].filter(
        (tab): tab is HTMLButtonElement => tab instanceof HTMLButtonElement,
      );
      if (tabs.length === 0) return;

      const theme = loadTheme();
      applyTheme(theme);

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => {
          const value = parseTheme(tab.dataset.value);
          applyTheme(value);
        });

        tab.addEventListener("keydown", (event) => {
          if (!(event.key === "ArrowRight" || event.key === "ArrowLeft")) return;
          event.preventDefault();
          const direction = event.key === "ArrowRight" ? 1 : -1;
          const nextIndex = (index + direction + tabs.length) % tabs.length;
          tabs[nextIndex]?.click();
        });
      });
    }
  }

  customElements.define("starlight-theme-select", StarlightThemeSelect);
</script>

<style>
  .lk-theme-tabs {
    --active-tab-left: 4px;
    --active-tab-width: 30px;
    --active-tab-top: 3px;
    --active-tab-height: 28px;
    display: flex;
  }

  .lk-theme-tablist {
    position: relative;
    display: inline-flex;
    width: fit-content;
    align-items: center;
    justify-content: center;
    height: 2.25rem;
    padding: 0.125rem;
    border: 0.5px solid var(--input);
    border-radius: calc(var(--radius) - 2px);
    background: var(--muted);
    color: var(--muted-foreground);
  }

  .lk-theme-indicator {
    pointer-events: none;
    position: absolute;
    top: var(--active-tab-top);
    left: var(--active-tab-left);
    z-index: 0;
    width: var(--active-tab-width);
    height: var(--active-tab-height);
    border-radius: calc(var(--radius) - 3px);
    background: var(--background);
    box-shadow: var(--shadow-sm);
    transition:
      left 150ms ease,
      width 150ms ease,
      top 150ms ease,
      height 150ms ease;
  }

  .lk-theme-tab {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.875rem;
    height: 1.75rem;
    padding: 0;
    border: 0;
    border-radius: calc(var(--radius) - 4px);
    background: transparent;
    color: color-mix(in oklab, var(--foreground) 60%, transparent);
    cursor: pointer;
    transition: color 120ms ease;
  }

  .lk-theme-tab:hover {
    color: var(--foreground);
  }

  .lk-theme-tab[data-state="active"] {
    color: var(--foreground);
  }

  .lk-theme-tab:focus-visible {
    outline: 2px solid color-mix(in oklab, var(--accent) 40%, transparent);
    outline-offset: 2px;
  }
</style>