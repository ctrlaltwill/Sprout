---
import { Code, Cpu, Layers3, Sparkles, Target } from "@lucide/astro";

const topFeatures = [
  {
    title: "Rich Card Types",
    description:
      "Create basic, cloze, image occlusion, multiple choice, and ordered questions in one flow without splitting your study process.",
    Icon: Layers3,
  },
  {
    title: "Companion",
    description:
      "Companion turns your notes into flashcards, tests, and study support on demand, helping you go from raw material to review-ready practice faster.",
    Icon: Sparkles,
  },
];

const bottomFeatures = [
  {
    title: "Coach",
    description:
      "Use adaptive guidance for weak areas, get focused follow-up prompts, and keep every session tied to your real notes.",
    Icon: Target,
  },
  {
    title: "FSRS",
    description:
      "Retention-based spacing decides when cards return, balancing workload and long-term memory so reviews stay consistent and sustainable.",
    Icon: Cpu,
  },
];

const orderedQuestionExample = [
  "T | Water cycle |",
  "OQ | Arrange the stages of the water cycle in order |",
  "1 | Evaporation |",
  "2 | Condensation |",
  "3 | Precipitation |",
  "4 | Collection |",
  "I | Water moves continuously through the atmosphere and the Earth's surface |",
  "G | Earth science |",
].join("\n");
---

<div class="home-panels">
  <div class="feature-grid" role="list" aria-label="LearnKit homepage highlights">
    {
      topFeatures.map(({ title, description, Icon }) => (
        <article class="feature-card" role="listitem">
          <p class="feature-title">
            <span class="feature-icon" aria-hidden="true">
              <Icon size={18} stroke-width={2.25} />
            </span>
            <span>{title}</span>
          </p>
          <p class="feature-body">{description}</p>
        </article>
      ))
    }
  </div>

  <article class="workflow-card">
    <div class="workflow-copy">
      <p class="feature-title workflow-kicker">
        <span class="feature-icon" aria-hidden="true">
          <Code size={18} stroke-width={2.25} />
        </span>
        <span>Markdown first</span>
      </p>
      <h2 class="workflow-title">Your note becomes the answer key.</h2>
      <p class="workflow-body">
        LearnKit is markdown-first by design. Write a flashcard using a simple syntax in your
        note, sync it, and then review it as an interactive flashcard.
      </p>
      <div class="workflow-links">
        <a href="./Ordered-Questions">See the ordered-question format</a>
        <a href="./Flashcards">See other flashcard types</a>
      </div>
    </div>

    <div class="workflow-code">
      <p class="code-label">In your note</p>
      <pre><code>{orderedQuestionExample}</code></pre>
    </div>
  </article>

  <div class="feature-grid" role="list" aria-label="LearnKit advanced highlights">
    {
      bottomFeatures.map(({ title, description, Icon }) => (
        <article class="feature-card" role="listitem">
          <p class="feature-title">
            <span class="feature-icon" aria-hidden="true">
              <Icon size={18} stroke-width={2.25} />
            </span>
            <span>{title}</span>
          </p>
          <p class="feature-body">{description}</p>
        </article>
      ))
    }
  </div>
</div>

<style>
  .home-panels {
    display: grid;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .feature-card {
    padding: 1.3rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1.25rem;
    background: var(--card);
    box-shadow: 0 6px 18px color-mix(in oklab, var(--foreground) 4%, transparent);
  }

  :global([data-theme="dark"]) .feature-card {
    background: color-mix(in oklab, var(--card) 96%, var(--muted));
    box-shadow: none;
  }

  .workflow-card {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.95fr);
    gap: 1.25rem;
    padding: 1.35rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1.4rem;
    background: color-mix(in oklab, var(--card) 86%, var(--muted));
  }

  .workflow-copy,
  .workflow-code {
    min-width: 0;
  }

  .workflow-kicker {
    margin: 0 0 0.9rem;
  }

  .workflow-title {
    margin: 5px 0 0;
    font-size: clamp(1.5rem, 2vw, 2rem);
    line-height: 1.15;
    color: var(--foreground);
  }

  .workflow-body {
    margin: 0.9rem 0 0;
    color: var(--muted-foreground);
    line-height: 1.7;
  }

  .workflow-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.15rem;
  }

  .workflow-links a {
    color: var(--foreground);
    font-weight: 650;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--foreground) 22%, transparent);
  }

  .workflow-links a:hover {
    border-bottom-color: var(--foreground);
  }

  .workflow-code {
    align-self: stretch;
    padding: 1rem;
    border-radius: 1.1rem;
    background: color-mix(in oklab, var(--muted) 85%, var(--background));
    border: 1px solid color-mix(in oklab, var(--border) 88%, transparent);
  }

  .code-label {
    margin: 0 0 0.8rem;
    font-size: 0.82rem;
    font-weight: 650;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .workflow-code pre {
    margin: 0;
    overflow-x: auto;
    font-size: 0.93rem;
    line-height: 1.7;
    color: var(--foreground);
    border: none;
  }

  .workflow-code code {
    font-family: var(--sl-font-mono, monospace);
  }

  .feature-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 0.7rem;
    font-size: 1rem;
    font-weight: 650;
    line-height: 1.3;
    color: var(--foreground);
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--primary) 12%, var(--background));
    color: var(--primary);
    flex: 0 0 auto;
  }

  .feature-body {
    margin: 0;
    color: var(--muted-foreground);
    line-height: 1.6;
  }

  @media (max-width: 60rem) {
    .workflow-card {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 50rem) {
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .workflow-card,
    .feature-card {
      padding: 1.1rem;
    }
  }
</style>