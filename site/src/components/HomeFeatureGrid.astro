---
import { Bot, Cpu, Layers3, Star } from "@lucide/astro";

const features = [
  {
    title: "Markdown-First Flashcards",
    description:
      "Write flashcards directly in your notes so study material stays close to the source and easy to maintain.",
    Icon: Star,
  },
  {
    title: "Rich Card Types",
    description:
      "Use basic, reversed, cloze, image occlusion, multiple choice, and ordered questions in one workflow.",
    Icon: Layers3,
  },
  {
    title: "Companion",
    description:
      "Ask questions about your notes, generate practice material, and draft flashcards from the same context.",
    Icon: Bot,
  },
  {
    title: "FSRS Scheduling",
    description:
      "LearnKit uses FSRS to time reviews around retention instead of fixed intervals.",
    Icon: Cpu,
  },
];
---

<div class="feature-grid" role="list" aria-label="LearnKit core features">
  {
    features.map(({ title, description, Icon }) => (
      <article class="feature-card" role="listitem">
        <p class="feature-title">
          <span class="feature-icon" aria-hidden="true">
            <Icon size={18} stroke-width={2.25} />
          </span>
          <span>{title}</span>
        </p>
        <p class="feature-body">{description}</p>
      </article>
    ))
  }
</div>

<style>
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .feature-card {
    padding: 1.2rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.58), rgba(255, 255, 255, 0.2)),
      var(--sl-color-black);
    box-shadow: 0 18px 48px rgba(15, 23, 42, 0.08);
  }

  :global([data-theme="dark"]) .feature-card {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01)),
      rgba(255, 255, 255, 0.02);
    box-shadow: none;
  }

  .feature-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 0.7rem;
    font-size: 1rem;
    font-weight: 650;
    line-height: 1.3;
    color: var(--sl-color-white);
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--sl-color-accent-high) 18%, transparent);
    color: var(--sl-color-accent-high);
    flex: 0 0 auto;
  }

  .feature-body {
    margin: 0;
    color: var(--sl-color-gray-2);
    line-height: 1.6;
  }

  @media (max-width: 50rem) {
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>