---
import { Code, Cpu, Layers3, Sparkles, Target } from "@lucide/astro";

const topFeatures = [
  {
    title: "Built for Every Recall Style",
    description:
      "Choose the right flashcard type for each concept, from quick fact recall or clozes to learning sequences and image occlusion.",
    Icon: Layers3,
  },
  {
    title: "Companion: From Notes to Practice, Faster",
    description:
      "Companion helps you turn captured ideas into review-ready material without switching between tools.",
    Icon: Sparkles,
  },
];

const bottomFeatures = [
  {
    title: "Coached to Success",
    description:
      "Coach keeps you moving with focused next steps, smarter follow-up questions, and guidance tied directly to your vault content.",
    Icon: Target,
  },
  {
    title: "Powered by the FSRS Algorithm",
    description:
      "Smart spacing powered by FSRS balances effort and retention, so your review queue stays manageable and your memory stays sharp.",
    Icon: Cpu,
  },
];

const orderedQuestionCard = {
  kicker: "Markdown first",
  title: "From markdown to memory, in one flow.",
  description:
    "Capture knowledge once, then practice it with multiple card formats without breaking your note workflow.",
  primaryLabel: "See the ordered-question format",
  primaryHref: "./Ordered-Questions",
  secondaryLabel: "See other flashcard types",
  secondaryHref: "./Flashcards",
  codeLabel: "Ordered question example",
  code: [
    "T | Water cycle |",
    "OQ | Arrange the stages of the water cycle in order |",
    "1 | Evaporation |",
    "2 | Condensation |",
    "3 | Precipitation |",
    "4 | Collection |",
    "I | Water moves continuously through the atmosphere and the Earth's surface |",
    "G | Earth science |",
  ].join("\n"),
};
---

<div class="home-panels">
  <div class="feature-grid" role="list" aria-label="LearnKit homepage highlights">
    {
      topFeatures.map(({ title, description, Icon }) => (
        <article class="feature-card" role="listitem">
          <p class="feature-title">
            <span class="feature-icon" aria-hidden="true">
              <Icon size={18} stroke-width={2.25} />
            </span>
            <span>{title}</span>
          </p>
          <p class="feature-body">{description}</p>
        </article>
      ))
    }
  </div>

  <article class="workflow-card">
    <div class="workflow-copy">
      <p class="feature-title workflow-kicker">
        <span class="feature-icon" aria-hidden="true">
          <Code size={18} stroke-width={2.25} />
        </span>
        <span>{orderedQuestionCard.kicker}</span>
      </p>
      <h2 class="workflow-title">{orderedQuestionCard.title}</h2>
      <p class="workflow-body">{orderedQuestionCard.description}</p>
      <div class="workflow-links">
        <a class="workflow-link-button workflow-link-button-primary" href={orderedQuestionCard.primaryHref}
          >{orderedQuestionCard.primaryLabel}</a
        >
        <a class="workflow-link-button workflow-link-button-secondary" href={orderedQuestionCard.secondaryHref}
          >{orderedQuestionCard.secondaryLabel}</a
        >
      </div>
    </div>

    <div class="workflow-code">
      <p class="code-label">{orderedQuestionCard.codeLabel}</p>
      <pre><code>{orderedQuestionCard.code}</code></pre>
    </div>
  </article>

  <div class="feature-grid" role="list" aria-label="LearnKit advanced highlights">
    {
      bottomFeatures.map(({ title, description, Icon }) => (
        <article class="feature-card" role="listitem">
          <p class="feature-title">
            <span class="feature-icon" aria-hidden="true">
              <Icon size={18} stroke-width={2.25} />
            </span>
            <span>{title}</span>
          </p>
          <p class="feature-body">{description}</p>
        </article>
      ))
    }
  </div>
</div>

<style>
  .home-panels {
    display: grid;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .feature-card {
    padding: 1.3rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1.25rem;
    background: var(--card);
    box-shadow: 0 6px 18px color-mix(in oklab, var(--foreground) 4%, transparent);
  }

  .feature-grid > .feature-card:nth-child(2n) {
    margin-top: 0;
    top: auto;
    transform: none;
  }

  :global([data-theme="dark"]) .feature-card {
    background: color-mix(in oklab, var(--card) 96%, var(--muted));
    box-shadow: none;
  }

  .workflow-card {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.95fr);
    gap: 1.25rem;
    padding: 1.35rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1.4rem;
    background: var(--card);
    box-shadow: 0 6px 18px color-mix(in oklab, var(--foreground) 4%, transparent);
  }

  :global([data-theme="dark"]) .workflow-card {
    background: color-mix(in oklab, var(--card) 96%, var(--muted));
    box-shadow: none;
  }

  .workflow-copy,
  .workflow-code {
    min-width: 0;
  }

  .workflow-kicker {
    margin: 0 0 0.9rem;
  }

  .workflow-title {
    margin: 5px 0 0;
    font-size: clamp(1.5rem, 2vw, 2rem);
    line-height: 1.15;
    color: var(--foreground);
  }

  .workflow-body {
    margin: 0.9rem 0 0;
    color: var(--muted-foreground);
    line-height: 1.7;
  }

  .workflow-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.15rem;
  }

  .workflow-link-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.2rem;
    padding: 0.42rem 0.8rem;
    border-radius: 0.65rem;
    border: 1px solid transparent;
    font-size: 0.86rem;
    font-weight: 640;
    line-height: 1.2;
    text-decoration: none;
    transition: background-color 120ms ease, border-color 120ms ease, color 120ms ease;
  }

  .workflow-link-button-primary {
    background: var(--primary);
    color: var(--sl-color-white);
    border-color: color-mix(in oklab, var(--primary) 75%, black);
  }

  .workflow-link-button-primary:hover {
    background: color-mix(in oklab, var(--primary) 86%, black);
  }

  .workflow-link-button-secondary {
    background: color-mix(in oklab, var(--card) 92%, var(--muted));
    color: var(--foreground);
    border-color: color-mix(in oklab, var(--foreground) 16%, transparent);
  }

  .workflow-link-button-secondary:hover {
    background: color-mix(in oklab, var(--card) 84%, var(--muted));
    border-color: color-mix(in oklab, var(--foreground) 28%, transparent);
  }

  :global([data-theme="dark"]) .workflow-link-button-primary {
    border-color: color-mix(in oklab, var(--primary) 50%, white);
  }

  :global([data-theme="dark"]) .workflow-link-button-secondary {
    background: color-mix(in oklab, var(--card) 90%, var(--muted));
    border-color: color-mix(in oklab, var(--foreground) 24%, transparent);
  }

  .workflow-code {
    align-self: stretch;
    padding: 1rem;
    border-radius: 1.1rem;
    background: color-mix(in oklab, var(--muted) 85%, var(--background));
    border: 1px solid color-mix(in oklab, var(--border) 88%, transparent);
  }

  .code-label {
    margin: 0 0 0.8rem;
    font-size: 0.82rem;
    font-weight: 650;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .workflow-code pre {
    margin: 0;
    overflow-x: auto;
    font-size: 0.93rem;
    line-height: 1.7;
    color: var(--foreground);
    border: none;
  }

  .workflow-code code {
    font-family: var(--sl-font-mono, monospace);
  }

  .feature-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 0.7rem;
    font-size: 1rem;
    font-weight: 650;
    line-height: 1.3;
    color: var(--foreground);
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--primary) 12%, var(--background));
    color: var(--primary);
    flex: 0 0 auto;
  }

  .feature-body {
    margin: 0;
    color: var(--muted-foreground);
    line-height: 1.6;
  }

  @media (max-width: 60rem) {
    .workflow-card {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 50rem) {
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .workflow-card,
    .feature-card {
      padding: 1.1rem;
    }
  }
</style>