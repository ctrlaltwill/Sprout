{
  "name": "learnkit",
  "version": "1.2.9",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev:js": "node tooling/esbuild.config.js --watch",
    "dev:css:tw": "npx @tailwindcss/cli -i ./src/styles.tailwind.css -o ./dist/styles.tmp.css --watch",
    "dev:css:scope": "mkdir -p dist && touch ./dist/styles.tmp.css && npx postcss ./dist/styles.tmp.css -o ./dist/styles.css --config tooling/postcss.config.cjs --watch",
    "dev:css": "concurrently -k \"npm:dev:css:tw\" \"npm:dev:css:scope\"",
    "dev": "concurrently -k \"npm:dev:js\" \"npm:dev:css\"",
    "build:js": "node tooling/esbuild.config.js --prod",
    "build:css": "npx @tailwindcss/cli -i ./src/styles.tailwind.css -o ./dist/styles.tmp.css --minify && npx postcss ./dist/styles.tmp.css -o ./dist/styles.css --config tooling/postcss.config.cjs && rm -f ./dist/styles.tmp.css",
    "build": "npm run build:js && npm run build:css && cp manifest.json dist/manifest.json",
    "check": "npm run lint && npm run translations:check && npm run i18n:literals:check && npm run test && npm run build",
    "build:local": "[ -f .local/build-local.sh ] && bash .local/build-local.sh || (echo 'Missing .local/build-local.sh (local-only helper).' && exit 1)",
    "deploy": "npm run build && cp dist/main.js dist/main.js.map dist/manifest.json dist/styles.css \"$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/Medicine/.obsidian/plugins/learnkit/\" && cp dist/main.js dist/main.js.map dist/manifest.json dist/styles.css \"$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/Medicine 17.09.35/.obsidian/plugins/learnkit/\"",
    "analyze": "node tooling/esbuild.config.js --prod --metafile=meta.json --analyze",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "docs:dev": "npm --prefix site run dev",
    "docs:build": "npm --prefix site run build",
    "docs:preview": "npm --prefix site run preview",
    "translations:check": "node tooling/check-locales.mjs",
    "i18n:literals:check": "node tooling/check-i18n-literals.mjs",
    "i18n:literals:baseline": "node tooling/check-i18n-literals.mjs --update-baseline",
    "lint": "eslint -c tooling/eslint.config.mjs src",
    "lint:fix": "eslint -c tooling/eslint.config.mjs src --fix"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^17.4.0",
    "obsidian": "^1.12.3",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-prefix-selector": "^2.1.1",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.38.6",
    "aos": "^2.3.4",
    "basecoat-css": "^0.3.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.0.11",
    "fflate": "^0.8.2",
    "interactjs": "^1.10.27",
    "marked": "^17.0.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.8.1",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "ts-fsrs": "^5.2.3"
  }
}
